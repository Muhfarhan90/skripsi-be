meta {
  name: Get Forum Post Detail
  type: http
  seq: 106
}

get {
  url: {{baseUrl}}/courses/{{courseId}}/forum/{{postId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/courses/{courseId}/forum/{postId}
  Action: App\Http\Controllers\Api\ForumController@show
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
