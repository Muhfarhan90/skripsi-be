meta {
  name: Delete Forum Post
  type: http
  seq: 105
}

delete {
  url: {{baseUrl}}/courses/{{courseId}}/forum/{{postId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/courses/{courseId}/forum/{postId}
  Action: App\Http\Controllers\Api\ForumController@destroy
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
