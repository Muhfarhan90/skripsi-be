meta {
  name: GET enrollments id
  type: http
  seq: 125
}

get {
  url: {{baseUrl}}/enrollments/{{id}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/enrollments/{id}
  Action: App\Http\Controllers\Api\EnrollmentController@show
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
