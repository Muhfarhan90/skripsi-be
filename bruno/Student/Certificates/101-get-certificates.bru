meta {
  name: GET certificates
  type: http
  seq: 101
}

get {
  url: {{baseUrl}}/certificates
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/certificates
  Action: App\Http\Controllers\Api\CertificateController@index
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
