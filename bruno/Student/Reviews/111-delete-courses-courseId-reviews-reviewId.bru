meta {
  name: Delete Course Review
  type: http
  seq: 111
}

delete {
  url: {{baseUrl}}/courses/{{courseId}}/reviews/{{reviewId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/courses/{courseId}/reviews/{reviewId}
  Action: App\Http\Controllers\Api\ReviewController@destroy
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
