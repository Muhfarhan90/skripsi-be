meta {
  name: Update Course Review
  type: http
  seq: 112
}

put {
  url: {{baseUrl}}/courses/{{courseId}}/reviews/{{reviewId}}
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {}
}

docs {
  URI: api/courses/{courseId}/reviews/{reviewId}
  Action: App\Http\Controllers\Api\ReviewController@update
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
