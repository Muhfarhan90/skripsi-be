meta {
  name: List Course Reviews
  type: http
  seq: 109
}

get {
  url: {{baseUrl}}/courses/{{courseId}}/reviews
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/courses/{courseId}/reviews
  Action: App\Http\Controllers\Api\ReviewController@index
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum
}
