meta {
  name: GET admin enrollments id
  type: http
  seq: 29
}

get {
  url: {{baseUrl}}/admin/enrollments/{{id}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/enrollments/{id}
  Action: App\Http\Controllers\Api\Admin\EnrollmentController@show
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum, App\Http\Middleware\EnsureAdminAccess
}
