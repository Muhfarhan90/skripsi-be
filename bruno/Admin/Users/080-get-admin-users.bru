meta {
  name: GET users.index
  type: http
  seq: 80
}

get {
  url: {{baseUrl}}/admin/users
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/users
  Action: App\Http\Controllers\Api\Admin\UserController@index
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum, App\Http\Middleware\EnsureAdminAccess
}
