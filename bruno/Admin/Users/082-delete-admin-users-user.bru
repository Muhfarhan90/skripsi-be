meta {
  name: DELETE users.destroy
  type: http
  seq: 82
}

delete {
  url: {{baseUrl}}/admin/users/{{user}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/users/{user}
  Action: App\Http\Controllers\Api\Admin\UserController@destroy
