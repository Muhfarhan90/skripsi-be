meta {
  name: List Forum Posts (Admin)
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/admin/courses/{{courseId}}/forum
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/courses/{courseId}/forum
  Action: App\Http\Controllers\Api\Admin\ForumController@index
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum, App\Http\Middleware\EnsureAdminAccess
}
