meta {
  name: Delete Forum Reply (Admin)
  type: http
  seq: 32
}

delete {
  url: {{baseUrl}}/admin/forum-replies/{{replyId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/forum-replies/{replyId}
  Action: App\Http\Controllers\Api\Admin\ForumController@destroyReply
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum, App\Http\Middleware\EnsureAdminAccess
}
