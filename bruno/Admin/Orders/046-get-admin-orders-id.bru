meta {
  name: GET admin orders id
  type: http
  seq: 46
}

get {
  url: {{baseUrl}}/admin/orders/{{id}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/orders/{id}
  Action: App\Http\Controllers\Api\Admin\OrderController@show
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum, App\Http\Middleware\EnsureAdminAccess
}
