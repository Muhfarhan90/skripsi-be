meta {
  name: Delete Course Review (Admin)
  type: http
  seq: 22
}

delete {
  url: {{baseUrl}}/admin/courses/{{courseId}}/reviews/{{reviewId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

docs {
  URI: api/admin/courses/{courseId}/reviews/{reviewId}
  Action: App\Http\Controllers\Api\Admin\ReviewController@destroy
  Middleware: api, Illuminate\Auth\Middleware\Authenticate:sanctum, App\Http\Middleware\EnsureAdminAccess
}
